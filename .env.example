# ============================================================
# CodeWithAhsan — Environment Variables Example
# ============================================================
# Copy this file to .env.local and fill in the values.
#
#   cp .env.example .env.local
#
# For local development with Firebase emulators, only the
# "Required" section below is needed. External service keys
# (email, Discord, etc.) are optional — features that depend
# on them will simply not work locally without them.
# ============================================================


# ============================================================
# REQUIRED — Local Development (Firebase emulators)
# ============================================================
# These vars are the minimum needed to run the dev server.
# When using Firebase emulators you do NOT need real Firebase
# credentials — the placeholder values below are sufficient.

# Firebase client SDK (safe to leave as-is for emulator use)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-codewithahsan
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDemoKeyForLocalDevelopmentOnly000
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-codewithahsan.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-codewithahsan.appspot.com
NEXT_PUBLIC_FIREBASE_MESSENGER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:000000000000000000000000
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase emulator hosts — tell SDKs to use local emulators
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Show/hide banners on the site
NEXT_PUBLIC_SHOW_BANNERS=false

# GitHub repo used for utterances comments widget
NEXT_PUBLIC_UTTERANCES_REPO=your-username/your-repo


# ============================================================
# OPTIONAL — External Services
# ============================================================
# Leave these empty while developing locally. Features that
# rely on them (emails, Discord bots, AI, analytics) will be
# disabled or will error gracefully.

# Email — Mailchimp newsletter integration
# Get from: https://mailchimp.com/developer/marketing/docs/fundamentals/#authentication
MAILCHIMP_API_KEY=
MAILCHIMP_API_SERVER=us1
MAILCHIMP_AUDIENCE_ID=

# Email — Resend transactional email
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL="Code With Ahsan <notifications@codewithahsan.dev>"
RESEND_REPLY_TO=no-reply@codewithahsan.dev

# Ghost Admin API — used to fetch draft posts for email blasts
# Get from: https://blog.codewithahsan.dev/ghost/#/settings/integrations → custom integration
# Format: <id>:<secret>
GHOST_ADMIN_API_KEY=
# Optional override (defaults to https://blog.codewithahsan.dev)
GHOST_ADMIN_URL=

# Discord bot (used for channel provisioning and notifications)
# Bot token: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_MENTORSHIP_CATEGORY_ID=
# Moderators / registration-notifications channel. Never deleted by the
# mentorship-end cleanup flows (VIS-141). Falls back to the CWA server channel.
DISCORD_MODERATORS_CHANNEL_ID=
DISCORD_WEBHOOK=

# AI — Google Gemini
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# AI — OpenAI (legacy)
OPEN_AI_SECRET=

# YouTube Data API v3
# Get from: https://console.cloud.google.com/apis/credentials
YT_API_KEY=

# Google OAuth (used for calendar integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
GOOGLE_CALENDAR_ENCRYPTION_KEY=

# Facebook / Meta (used for social cross-posting)
FB_PAGE_ACCESS_TOKEN=
FB_USER_ACCESS_TOKEN=
FB_USER_ID=
CODE_WITH_AHSAN_PAGE_ID=

# Strapi CMS (legacy content source)
STRAPI_URL=
STRAPI_API_KEY=

# Quote of the Day API
QOD_EP_API_KEY=

# Admin user email (used for seeding admin role locally)
ADMIN_EMAIL=admin@example.com
# Admin dashboard password for local dev — set by `npm run seed` (password: "admin")

# Loupe feedback widget
# Get from: https://loupe.ink
NEXT_PUBLIC_LOUPE_API_KEY=


# ============================================================
# PRODUCTION ONLY — Do not set locally
# ============================================================
# These are only needed when deploying to Vercel / Cloud Run.
# Never put real service account keys in .env.local unless
# you are testing Admin SDK flows outside the emulator.

# Vercel OIDC (set automatically by Vercel CI)
# VERCEL_OIDC_TOKEN=

# Firebase Admin SDK credentials (one of the two options):
#   Option A — JSON blob of the service account key file
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
#
#   Option B — Individual key fields
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id   (already set above for emulators)
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."

# ── ADK Agent / Semantic Search ──────────────────────────────────────────────
# Google AI Studio API key (used by embed script + semantic-search endpoint)
GOOGLE_API_KEY=

# Platform API base URL (used by Python agent platform_client)
# Override for local dev: http://localhost:3000
PLATFORM_API_BASE_URL=https://codewithahsan.dev

# ─── v6.0 Student Ambassador Program feature flag ──────────────
# Turn on at the start of Phase 2. Requires a redeploy to take effect (~30s).
# Both server and client halves must be "true" to enable.
# When unset or any value other than "true", /ambassadors/* and /admin/ambassadors
# return 404 and the header/footer nav items are filtered out.
FEATURE_AMBASSADOR_PROGRAM=false
NEXT_PUBLIC_FEATURE_AMBASSADOR_PROGRAM=false
