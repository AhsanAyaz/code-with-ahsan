# Discord bot — get from https://discord.com/developers/applications → CWA Assistant → Bot
CWA_ASSISTANT_DISCORD_BOT_TOKEN=

# The single channel where the bot listens for @mentions
# Right-click channel in Discord (Developer Mode on) → Copy Channel ID
ASSISTANT_CHANNEL_ID=

# Gemini API key for the agent's LLM calls (root_agent uses gemini-2.5-flash)
GOOGLE_API_KEY=

# Platform API base URL — production for Cloud Run, http://localhost:3000 for local dev
PLATFORM_API_BASE_URL=https://codewithahsan.dev
